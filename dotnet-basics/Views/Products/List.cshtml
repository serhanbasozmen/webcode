@model List<Product>

<div class="row">
    <div class="col-4">
        <div class="card mb-3">
            <div class="row">
                <div class="col-md-4">
                    <img src="/img/@Model[0].productImage" class="img-fluid rounded-start"> </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">@Model[0].productTitle</h5> <p class="card-text">@Model[0].productExplation</p>
                        <button class="btn btn-warning btn-sm">Details</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-4">
        <div class="card mb-3">
            <div class="row">
                <div class="col-md-4">
                    <img src="/img/@Model[1].productImage" class="img-fluid rounded-start"> </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">@Model[1].productTitle</h5> <p class="card-text">@Model[1].productExplation</p>
                        <button class="btn btn-warning btn-sm">Details</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card mb-3">
            <div class="row">
                <div class="col-md-4">
                    <img src="/img/@Model[2].productImage" class="img-fluid rounded-start"> </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">@Model[2].productTitle</h5> <p class="card-text">@Model[2].productExplation</p>
                        <button class="btn btn-warning btn-sm">Details</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>