@model Cart

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#">Homepage</a>
                    </li>
                    <li class="breadcrumb-item">Shopping Cart</li>
                </ol>
            </nav>
        </div>
    </section>
}


<section class="mt-3">
    <div class="container">
        @if (@Model.CartItems.Count == 0)
        {
            <div class="alert alert-warning">
                There are no items in the cart.
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-7">
                    <ul class="list-group">
                        @foreach (var item in Model.CartItems)
                        {
                            <li class="py-3 mb-2 border-top list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-7">
                                        <div class="d-flex align-items-center">
                                            <img src="~/img/@item.Product.Image" style="width: 100px" alt="" />
                                            <div class="ms-3">
                                                <a class="text-decoration-none" href="#">
                                                    <h6 class="mb-0">@item.Product.ProductName</h6>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-2">
                                        <input type="number" value="@item.Amount" class="form-control" min="1">
                                    </div>
                                    <div class="col-2 text-center">
                                        <span class="fw-bold">@item.Product.Price</span>
                                    </div>
                                    <div class="col-1">
                                        <form action="/Cart/RemoveItem" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductId">
                                            <input type="hidden" name="amount" value="@item.Amount">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="col-lg-5">
                    <div class="card">
                        <div class="p-3 card-body">
                            <h2 class="h5 mb-4">Order Summary</h2>
                            <div class="card mb-2">
                                <div class="list-group list-group-flush">
                                    <div class="d-flex justifty-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Order Total</div>
                                        </div>
                                        <span>@Model.SubTotal() ₺</span>
                                    </div>
                                    <div class="d-flex justifty-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Delivery Price</div>
                                        </div>
                                        <span>Free</span>
                                    </div>
                                    <div class="d-flex justifty-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Tax Fee(20%)</div>
                                        </div>
                                        <span>@(Model.SubTotal() * 0.2) ₺</span>
                                    </div>
                                    <div class="d-flex justifty-content-center align-items-center list-group-item">
                                        <div class="me-auto">
                                            <div>Totally</div>
                                        </div>
                                        <span>@Model.Total() ₺</span>
                                    </div>
                                </div>
                            </div>
                            <div class="d-grid">
                                <a href="#" class="btn btn-primary btn-lg">
                                    Complete Order
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>