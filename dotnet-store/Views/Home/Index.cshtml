@model List<Product>

@{
    ViewData["Title"] = "Home Page";
}

    <section class="mt-3">
      <div class="container">
        <div class="card">
          <div class="row p-1 p-lg-2 gx-2">
            <div class="col-lg-3 d-none d-lg-block">
              <!-- menu -->
                 @await Html.PartialAsync("Partials/_Menu", ViewData["Categories"])
            </div>
            <div class="col-lg-9">
              <!-- sliderk -->
               @await Component.InvokeAsync("Slider")
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-3">
      <div class="container">
        <h3 class="h4 mb-1 mb-lg-3">Recently Added</h3>

         <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach(var product in Model)
            {
          <div class="col">
             @await Html.PartialAsync("Partials/_ProductCard", product)
          </div>
            }  
        </div>
      </div>
    </section>