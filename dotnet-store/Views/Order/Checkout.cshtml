@model OrderCreateModel

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#">Homepage</a>
                    </li>
                    <li class="breadcrumb-item">Complete Order</li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h2 class="h6 mb-0">Order Details</h2>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="row mb-3">
                                <div class="col">
                                    <label asp-for="FullName" class="form-label"></label>
                                    <input asp-for="FullName" class="form-control">
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col">
                                        <label asp-for="City" class="form-label"></label>
                                        <input asp-for="City" class="form-control">
                                        </div>
                                        <div class="col">
                                            <label asp-for="Phone" class="form-label"></label>
                                            <input asp-for="Phone" class="form-control">
                                            </div>
                                            <div class="col">
                                                <label asp-for="PostCode" class="form-label"></label>
                                                <input asp-for="PostCode" class="form-control">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <div class="col">
                                                    <label asp-for="AddressLine" class="form-label"></label>
                                                    <textarea asp-for="AddressLine" class="form-control" rows="3"></textarea>
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <div class="col">
                                                    <label asp-for="OrderNote" class="form-label"></label>
                                                    <textarea asp-for="OrderNote" class="form-control" rows="3"></textarea>
                                                </div>
                                            </div>
                                            <div class="d-grid mt-3">
                                                <button type="submit" asp-controller="Order" asp-action="Checkout"
                                                        class="btn btn-primary btn-lg">
                                                    Complete Order
                                                </button>
                                            </div>
                                        </form>
                                        
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-header">
                                        <h2 class="h6 mb-0">Order Summary</h2>
                                    </div>
                                    <div class="card-body">
                                        <div class="list-group">
                                            @foreach (var item in ViewBag.Cart.CartItems)
                                            {
                                                <div class="d-flex justify-content-between align-items-center list-group-item">
                                                    <p class="mb-0">@item.Product.ProductName ( @item.Amount x)</p>
                                                    <span>@(item.Product.Price * item.Amount) ₺</span>
                                                </div>
                                            }
                                            <div class="d-flex justify-content-between align-items-center list-group-item ">
                                                <p class="mb-0">SubTotal</p>
                                                <span>@ViewBag.Cart.SubTotal() ₺</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center list-group-item text-success">
                                                <p class="mb-0">Total</p>
                                                <span class="fs-5">@ViewBag.Cart.Total() ₺</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                              
                            </div>
                        </div>
                    </div>
                </section>