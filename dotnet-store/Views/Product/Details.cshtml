@model Product

@section Bar {
    @await Component.InvokeAsync("Navbar")
}
 
<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="gallery-wrap">
                    <div class="img-big-wrap img-thumbnail">
                        <a href="~/img/@Model.Image" data-type="image" data-fslightbox>
                            <img src="~/img/@Model.Image" alt="" />
                        </a>
                    </div>
                    <div class="thumbs-wrap">
                        <a href="~/img/1-big.jpeg" data-type="image" data-fslightbox>
                            <img src="~/img/1.jpeg" height="60" alt="" />
                        </a>
                        <a href="~/img/2-big.jpeg" data-type="image" data-fslightbox>
                            <img src="~/img/2.jpeg" height="60" alt="" />
                        </a>

                        <a href="~/img/3-big.jpeg" data-type="image" data-fslightbox>
                            <img src="~/img/3.jpeg" height="60" alt="" />
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <!-- product details -->
                <article>
                    <h4 class="title text-dark">
                        @Model.ProductName
                    </h4>
                    <div class="rating-wrap">
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star"></span>
                    </div>
                    <p class="text-success">Stocked</p>
                    <div class="mb-3"><b class="price h5">@Model.Price ₺</b></div>
                    <div class="product-description mb-3">
                        @Model.Explanation
                    </div>
                    <div class="buttons">
                        <form action="/Cart/AddToCart" method="post" class="me-1 d-inline">
                            <input type="hidden" name="productId" value="@Model.Id">
                            <button type="submit" href="#" class="btn btn-warning">
                                <i class="fa fa-shopping-basket"></i> Add To Cart
                            </button>
                        </form>
                        <a href="#" class="btn btn-danger">
                            <i class="fa-regular fa-heart me-1"></i> Add To List
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

@{
    var products = (List<Product>)ViewData["SimilarProducts"]!;
    
    if (products.Count > 0)
    {

        <section class="mt-3">
            <div class="container">
                <h4 class="mb-3">Similar Products</h4>
                <div class="row gy-3">

                    @foreach (var item in products)
                    {

                        <div class="col-lg-3 col-sm-6 col-12">
                            <div class="card shadow">
                                <div class="img-wrap">
                                    <span class="fa fa-regular fa-heart"></span>
                                    <img src="~/img/@item.Image" alt="@item.ProductName" class="card-img-top" />
                                </div>
                                <div class="border-top info-wrap">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id"
                                       class="title text-truncate">@item.ProductName</a>
                                    <div class="price-wrap mb-3">
                                        <span class="price-discount">@item.Price ₺</span>
                                        @* <del class="price">42.560 ₺</del> *@
                                    </div>
                                    <a href="#" class="btn btn-light w-100">
                                        <i class="fa fa-shopping-basket me-1"></i>Add To Cart
                                    </a>
                                </div>
                            </div>
                        </div>

                    }

           
                </div>
            </div>
        </section>
    }
}
