@model List<Product>

@section Bar{
      @await Component.InvokeAsync("Navbar")
 }

    <section class="mt-3">
      <div class="container">
        <h3 class="h4 mb-1 mb-lg-3">Product List</h3>

        @if(Model.Count == 0){
            <div class="alert alert-danger">Product Not Found</div>
        }

        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach(var product in Model)
            {
          <div class="col">
             @await Html.PartialAsync("Partials/Site/_ProductCard",product)
          </div>
            }  
        </div>
      </div>
    </section>